# Public frontend URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Server-side URL used by Next.js API routes.
# In Docker Compose this should be http://directus:8055.
DIRECTUS_INTERNAL_URL=http://localhost:8055

# Directus
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_SECRET=replace-with-a-long-random-secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me-now

# PostgreSQL
POSTGRES_DB=crew_desk
POSTGRES_USER=crew_desk
POSTGRES_PASSWORD=change-me-now
POSTGRES_PORT=5433
