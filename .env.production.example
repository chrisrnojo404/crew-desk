# Public URLs
NEXT_PUBLIC_APP_URL=https://crew-desk.example.com
NEXT_PUBLIC_DIRECTUS_URL=https://directus.crew-desk.example.com

# Server-side URL used by Next.js API routes inside Docker Compose.
DIRECTUS_INTERNAL_URL=http://directus:8055

# Directus
DIRECTUS_PUBLIC_URL=https://directus.crew-desk.example.com
DIRECTUS_KEY=replace-with-a-32-character-random-key
DIRECTUS_SECRET=replace-with-a-long-random-secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=replace-with-a-strong-password
DIRECTUS_CORS_ORIGIN=https://crew-desk.example.com

# PostgreSQL
POSTGRES_DB=crew_desk
POSTGRES_USER=crew_desk
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Deployment
WEB_PORT=3000
DIRECTUS_PORT=8055
